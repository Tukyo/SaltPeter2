{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2025", "DOM", "DOM.Iterable"],
    "moduleResolution": "Bundler",
    "noEmit": true,
    "strict": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": ["@webgpu/types"],
    "paths": {
      "@Nitrate": ["./src/engine/Nitrate.ts"]
    }
  },
  "include": ["src", "vite-env.d.ts"]
}
